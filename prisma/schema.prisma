generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

//enums
enum Role {
  CITIZEN
  AGENCY
}

enum ProjectStatus {
  PLANNING
  FUNDING
  EXECUTING
  COMPLETED
}

enum SentimentLabel {
  POSITIVE
  NEGATIVE
  NETRAL
}

enum VoteType {
  UPVOTE
  DOWNVOTE
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
}

enum NotificationType {
  NEW_PROJECT
  REPLY_COMMENT
  DONATION_STATUS
  PROJECT_UPDATE
}

//models
model Village {
  id          String    @id @default(uuid())
  name        String    @unique

  //relations
  citizens  CitizenProfile[]
  projects  Project[]
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  role        Role
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  //relations
  citizenProfile  CitizenProfile?
  agencyProfile   AgencyProfile?

  comments      Comment[]
  votes         Vote[]
  donations     Donation[]
  notifications Notification[]
}

model CitizenProfile {
  id          String  @id @default(uuid())
  fullName    String 
  isVerified  Boolean @default(false)

  //relations
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id])

  villageId   String
  villate     Village @relation(fields: [villageId], references: [id])

}

model AgencyProfile {
  id          String  @id @default(uuid())
  agencyName  String 

  //relations
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id])

  projects    Project[]
}

model Project {
  id              String        @id @default(uuid())
  title           String
  description     String
  status          ProjectStatus @default(PLANNING)
  budgetTarget    Decimal       @default(0)
  currentFunding  Decimal       @default(0)
  priorityScore   Float         @default(0)
  latitude        Float
  longitude       Float

  //relations
  villageId       String
  village         Village       @relation(fields: [villageId], references: [id])

  agencyId        String
  agency          AgencyProfile @relation(fields: [agencyId], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  comments        Comment[]
  votes           Vote[]
  donations       Donation[]
  updates         ProjectUpdate[]
  notifications   Notification[]
}

model Comment {
  id              String        @id @default(uuid())
  text            String        
  sentimentLabel  SentimentLabel
  sentimentScore  Float         @default(0)
  cratedAt        DateTime      @default(now())
  
  //relations
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id])

  userId          String
  user            User          @relation(fields: [userId], references: [id])
}

model Vote {
  id              String        @id @default(uuid())
  type            VoteType

  projectId       String
  project         Project       @relation(fields: [projectId], references: [id])

  userId          String
  user            User          @relation(fields: [userId], references: [id])

  createdAt       DateTime      @default(now())

  @@unique([projectId, userId])
}

model Donation {
  id            String         @id @default(uuid())
  orderId       String         @unique
  amount        Decimal
  status        DonationStatus @default(PENDING)
  paymentMethod String?
  
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id])
  
  userId        String?
  user          User?          @relation(fields: [userId], references: [id])
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ProjectUpdate {
  id          String   @id @default(uuid())
  title       String
  description String
  imageUrl    String?
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  
  createdAt   DateTime @default(now())
}

model Notification {
  id        String           @id @default(uuid())
  title     String
  message   String
  isRead    Boolean          @default(false)
  type      NotificationType
  
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  
  projectId String?
  project   Project?         @relation(fields: [projectId], references: [id])
  
  createdAt DateTime         @default(now())
}

model RegionBoundary {
  id    String   @id @default(uuid())
  name  String
  geom  Unsupported("geometry(Polygon, 4326)")
}